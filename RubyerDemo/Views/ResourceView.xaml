<UserControl x:Class="RubyerDemo.Views.ResourceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:RubyerDemo.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RubyerDemo.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:rubyer="http://rubyer.io/winfx/xaml/toolkit"
             xmlns:smtx="clr-namespace:ShowMeTheXAML;assembly=ShowMeTheXAML"
             xmlns:viewmodels="clr-namespace:RubyerDemo.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewmodels:ResourceViewModel}"
             mc:Ignorable="d">
    <smtx:XamlDisplay UniqueKey="ResourceView">
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10"
                        rubyer:GridHelper.RowDefinitions="Auto, Auto"
                        rubyer:PanelHelper.Spacing="10">
                <controls:ControlDisplay Title="Colors 颜色">
                    <TabControl Style="{StaticResource LineTabControl}"
                                Padding="0"
                                rubyer:HeaderHelper.Padding="20 5">
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel rubyer:PanelHelper.Spacing="8" Orientation="Horizontal">
                                    <rubyer:Icon Type="SunLine" />
                                    <TextBlock FontSize="18" Text="Light" />
                                </StackPanel>
                            </TabItem.Header>
                            <DataGrid HorizontalContentAlignment="Center"
                                      rubyer:HeaderHelper.FontSize="18"
                                      rubyer:HeaderHelper.HorizontalAlignment="Center"
                                      AutoGenerateColumns="False"
                                      BorderThickness="1"
                                      ItemsSource="{Binding LightColorInfos}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Color">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Width="24"
                                                        Height="24"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="5">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding Color, Mode=OneWay}" />
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Binding="{Binding Key}" Header="Key" />
                                    <DataGridTextColumn Binding="{Binding Color}" Header="Hex" />
                                    <DataGridTextColumn Binding="{Binding Description}" Header="Description" />
                                    <DataGridTemplateColumn Header="">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource TextButton}"
                                                        rubyer:ButtonHelper.IconType="FileCopyFill"
                                                        Command="{Binding DataContext.CopyColorCommand, RelativeSource={RelativeSource AncestorType=local:ResourceView}}"
                                                        CommandParameter="{Binding .}"
                                                        Foreground="{DynamicResource DefaultForeground}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <StackPanel rubyer:PanelHelper.Spacing="8" Orientation="Horizontal">
                                    <rubyer:Icon Type="MoonLine" />
                                    <TextBlock FontSize="18" Text="Dark" />
                                </StackPanel>
                            </TabItem.Header>
                            <DataGrid HorizontalContentAlignment="Center"
                                      rubyer:HeaderHelper.FontSize="18"
                                      rubyer:HeaderHelper.HorizontalAlignment="Center"
                                      AutoGenerateColumns="False"
                                      BorderThickness="1"
                                      ItemsSource="{Binding DarkColorInfos}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Color">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Width="24"
                                                        Height="24"
                                                        BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="5">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="{Binding Color, Mode=OneWay}" />
                                                    </Border.Background>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Binding="{Binding Key}" Header="Key" />
                                    <DataGridTextColumn Binding="{Binding Color}" Header="Hex" />
                                    <DataGridTextColumn Binding="{Binding Description}" Header="Description" />
                                    <DataGridTemplateColumn Header="">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource TextButton}"
                                                        rubyer:ButtonHelper.IconType="FileCopyFill"
                                                        Command="{Binding DataContext.CopyColorCommand, RelativeSource={RelativeSource AncestorType=local:ResourceView}}"
                                                        CommandParameter="{Binding .}"
                                                        Foreground="{DynamicResource DefaultForeground}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </controls:ControlDisplay>
            </StackPanel>
        </ScrollViewer>
    </smtx:XamlDisplay>
</UserControl>
